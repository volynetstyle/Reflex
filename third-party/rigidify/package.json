  },
  "homepage": "https://github.com/your-username/rigidify#readme",
  "devDependencies": {
    "rollup": "^4.50.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.2",
    "eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
