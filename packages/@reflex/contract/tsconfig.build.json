{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,

    "outDir": "./dist",
    "rootDir": "./src",

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    "stripInternal": true
  },

  "include": ["src"]
}
