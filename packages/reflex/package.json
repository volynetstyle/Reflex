{
  "name": "reflex",
  "version": "0.1.0",
  "type": "module",
  "description": "Reactive libriary for purpouses js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json"
  },
  "dependencies": {
    "@reflex/core": "workspace:*",
    "@reflex/runtime": "workspace:*"
  }
}
