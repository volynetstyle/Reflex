{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build/esm",
    "module": "ESNext",
    "target": "ES2022",
    "baseUrl": ".",
    "declaration": true,
    "declarationDir": "build/types",
    "emitDeclarationOnly": false,
    "tsBuildInfoFile": "build/tsconfig.build.tsbuildinfo"
  },
  "include": ["src"]
}
