{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "isolatedModules": true,
    "strict": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": ["dist"]
}
