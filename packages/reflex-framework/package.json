{
  "name": "@volynets/reflex-framework",
  "version": "0.1.0",
  "type": "module",
  "description": "Platform-agnostic JSX runtime and renderable model for Reflex",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "source": {
        "types": "./src/jsx-runtime.ts",
        "default": "./src/jsx-runtime.ts"
      },
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "source": {
        "types": "./src/jsx-dev-runtime.ts",
        "default": "./src/jsx-dev-runtime.ts"
      },
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./ownership": {
      "source": {
        "types": "./src/ownership/index.ts",
        "default": "./src/ownership/index.ts"
      },
      "types": "./dist/ownership/index.d.ts",
      "import": "./dist/ownership/index.js"
    },
    "./ownership/reflex": {
      "source": {
        "types": "./src/ownership/reflex.ts",
        "default": "./src/ownership/reflex.ts"
      },
      "types": "./dist/ownership/reflex.d.ts",
      "import": "./dist/ownership/reflex.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "build": "node ./scripts/clean.mjs && node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json && node ../../scripts/fix-esm-specifiers.mjs dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm exec vitest run --config vite.config.ts",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.typecheck.json",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@volynets/reflex": "workspace:*"
  },
  "keywords": [
    "jsx",
    "reactivity",
    "renderer",
    "runtime",
    "reflex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volynetstyle/Reflex.git",
    "directory": "packages/reflex-framework"
  },
  "homepage": "https://github.com/volynetstyle/Reflex/tree/main/packages/reflex-framework",
  "bugs": {
    "url": "https://github.com/volynetstyle/Reflex/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
