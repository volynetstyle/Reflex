{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@volynets/reflex": ["../reflex/src/index.ts"],
      "@volynets/reflex-framework": [
        "../reflex-framework/src/index.ts",
        "../reflex-framework/dist/index.d.ts"
      ],
      "@volynets/reflex-framework/ownership": [
        "../reflex-framework/src/ownership/index.ts",
        "../reflex-framework/dist/ownership/index.d.ts"
      ],
      "@volynets/reflex-framework/ownership/reflex": [
        "../reflex-framework/src/ownership/reflex.ts",
        "../reflex-framework/dist/ownership/reflex.d.ts"
      ],
      "@volynets/reflex-framework/jsx-runtime": [
        "../reflex-framework/src/jsx-runtime.ts",
        "../reflex-framework/dist/jsx-runtime.d.ts"
      ],
      "@volynets/reflex-framework/jsx-dev-runtime": [
        "../reflex-framework/src/jsx-dev-runtime.ts",
        "../reflex-framework/dist/jsx-dev-runtime.d.ts"
      ]
    },
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.typecheck.tsx"]
}
