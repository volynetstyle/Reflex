{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "reflex-framework": ["../reflex-framework/dist/index.d.ts"],
      "reflex-framework/ownership": [
        "../reflex-framework/dist/ownership/index.d.ts"
      ],
      "reflex-framework/ownership/reflex": [
        "../reflex-framework/dist/ownership/reflex.d.ts"
      ],
      "reflex-framework/jsx-runtime": [
        "../reflex-framework/dist/jsx-runtime.d.ts"
      ],
      "reflex-framework/jsx-dev-runtime": [
        "../reflex-framework/dist/jsx-dev-runtime.d.ts"
      ]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "customConditions": ["source"],
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "**/*.test.ts"]
}
