{
  "name": "reflex-dom",
  "version": "0.1.0",
  "type": "module",
  "description": "DOM renderer for Reflex",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "source": {
        "types": "./src/vite.ts",
        "default": "./src/vite.ts"
      },
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./jsx-runtime": {
      "source": {
        "types": "./src/jsx-runtime.ts",
        "default": "./src/jsx-runtime.ts"
      },
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "source": {
        "types": "./src/jsx-dev-runtime.ts",
        "default": "./src/jsx-dev-runtime.ts"
      },
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm exec vitest run --config vite.config.ts",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@swc/core": "^1.15.18",
    "@volynets/reflex": "workspace:*",
    "reflex-framework": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  }
}
