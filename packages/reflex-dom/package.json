{
  "name": "@volynets/reflex-dom",
  "version": "0.0.2",
  "type": "module",
  "description": "DOM renderer for Reflex",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "source": {
        "types": "./src/jsx-runtime.ts",
        "default": "./src/jsx-runtime.ts"
      },
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "source": {
        "types": "./src/jsx-dev-runtime.ts",
        "default": "./src/jsx-dev-runtime.ts"
      },
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('build',{recursive:true,force:true});require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json && node ../../scripts/fix-esm-specifiers.mjs dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm exec vitest run --config vite.config.ts",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.typecheck.json",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@volynets/reflex": "workspace:*",
    "@volynets/reflex-framework": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  },
  "keywords": [
    "dom",
    "jsx",
    "reactivity",
    "renderer",
    "reflex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volynetstyle/Reflex.git",
    "directory": "packages/reflex-dom"
  },
  "homepage": "https://github.com/volynetstyle/Reflex/tree/main/packages/reflex-dom",
  "bugs": {
    "url": "https://github.com/volynetstyle/Reflex/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
